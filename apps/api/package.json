{
  "name": "@alex-1883-test-34/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "npm run db:generate && tsc -p tsconfig.json",
    "db:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema ../../prisma/schema.prisma",
    "db:validate": "prisma validate --schema ../../prisma/schema.prisma",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "npm run db:generate && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.699.0",
    "@prisma/client": "^6.18.0",
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0"
  }
}
