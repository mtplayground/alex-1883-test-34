# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=8080

# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/database?schema=public

# Object Storage
OBJECT_STORAGE_ENDPOINT=https://example-object-storage-endpoint
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=example-bucket
OBJECT_STORAGE_ACCESS_KEY_ID=example-access-key
OBJECT_STORAGE_SECRET_ACCESS_KEY=example-secret-key
OBJECT_STORAGE_PREFIX=uploads
OBJECT_STORAGE_PUBLIC_BASE_URL=https://cdn.example.com/example-bucket

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=example-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=example-google-client-secret
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
